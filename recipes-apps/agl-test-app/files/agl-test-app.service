[Unit]
Requires=agl-compositor.service
After=agl-compositor.service

[Service]
User=agl-driver
EnvironmentFile=/etc/default/flutter
EnvironmentFile=-/etc/default/agl-test-app
Environment=XDG_RUNTIME_DIR=/run/user/1001/
ExecStart=/usr/bin/flutter-auto -b /usr/share/flutter/agl-test-app/${FLUTTER_VERSION}/${FLUTTER_RUNTIME} --xdg-shell-app-id agl-test-app

[Install]
WantedBy=graphical.target
